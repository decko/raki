{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["ticket_key", "branch", "commits", "files_changed", "task_results", "tests_passed"],
  "properties": {
    "ticket_key": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hash", "message", "task_id"],
        "properties": {
          "hash": { "type": "string" },
          "message": { "type": "string" },
          "task_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["created", "modified", "deleted"]
          }
        },
        "additionalProperties": false
      }
    },
    "task_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "skipped"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "tests_passed": {
      "type": "boolean"
    },
    "test_output": {
      "type": "string"
    },
    "deviations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
