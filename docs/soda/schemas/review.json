{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["ticket_key", "findings", "verdict"],
  "properties": {
    "ticket_key": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "rework"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "issue", "suggestion"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "IMPORTANT", "MINOR"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
