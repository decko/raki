{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["ticket_key", "verdict", "perspectives"],
  "properties": {
    "ticket_key": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "rework"]
    },
    "perspectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "verdict", "findings"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["python", "security", "rag", "doc"]
          },
          "verdict": {
            "type": "string",
            "enum": ["clean", "needs_fixes"]
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["severity", "file", "issue"],
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": ["CRITICAL", "IMPORTANT", "MINOR"]
                },
                "file": { "type": "string" },
                "line": { "type": "integer" },
                "issue": { "type": "string" },
                "suggestion": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "routing_reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
